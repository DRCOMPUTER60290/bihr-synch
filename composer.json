{
    "name": "drcomputer60290/bihr-synch",
    "description": "Import des catalogues Bihr (Prix, Images, Attributs, Stocks) et cr\u00e9ation de produits WooCommerce.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "DrComputer60290",
            "email": "webmaster@drcomputer60290.fr"
        }
    ],
    "autoload": {
        "classmap": [
            "includes/",
            "admin/"
        ]
    },
    "require": {
        "php": ">=7.4",
        "composer/installers": "^2.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "php-stubs/wordpress-stubs": "^6.5",
        "php-stubs/woocommerce-stubs": "^9.0",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    },
    "scripts": {
        "lint": "phpcs --standard=WordPress --extensions=php includes/ admin/",
        "lint-fix": "phpcbf --standard=WordPress --extensions=php includes/ admin/"
    }
}
